[sub_resource type="GDScript" id="GDScript_bn856"]
script/source = "extends Label
@export var rootlevel: Level

func _ready() -> void:
	self.text = (\"Score Target: \" +str(rootlevel.score_target))
	
"

[sub_resource type="GDScript" id="GDScript_gac28"]
script/source = "extends Label
@export var rootlevel: Level


func _ready() -> void:
	rootlevel.on_lives_changed.connect(update_text)
	update_text.call_deferred()

func update_text():
	self.text = (\"Lives: \" +str(rootlevel.current_lives))
"

