[sub_resource type="GDScript" id="GDScript_q4at1"]
script/source = "extends Button

func _ready() -> void:
	button_pressed = Overlays.is_CRT_enabled
	pressed.connect(_on_button_pressed)

func _on_button_pressed():
	Overlays.set_crt(button_pressed)
	print(\"set? \", Overlays.is_CRT_enabled, button_pressed)
"

[sub_resource type="GDScript" id="GDScript_bdxpv"]
script/source = "extends Button

func _ready() -> void:
	pressed.connect(_on_button_pressed)
	button_pressed = GameManager.run_timer_on

func _on_button_pressed():
	GameManager.set_run_timer_toggle(button_pressed)
"

[sub_resource type="GDScript" id="GDScript_6f4k2"]
script/source = "extends Button

@export var phrases: Array[String]

func _ready() -> void:
	button_down.connect(_on_button_pressed)

func _on_button_pressed():
	GameManager.create_small_splash(phrases.pick_random(), false)
"

[sub_resource type="GDScript" id="GDScript_xdkfq"]
script/source = "extends Button

@export var credits: Control

func _ready() -> void:
	pressed.connect(_on_button_pressed)

func _on_button_pressed():
	credits.hide_credits()
	pass
"

